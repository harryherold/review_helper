import { GroupBox, HorizontalBox, Palette } from "std-widgets.slint";

import { Style } from "style.slint";
import { SlintDifferenceStatistics, SlintChangeTypeUtils } from "globals.slint";

export component OverallStatistics inherits HorizontalLayout {
    in property <SlintDifferenceStatistics> difference_statistics;
    alignment: start;
    for data in root.difference_statistics.change_type_model: VerticalLayout {
        Image {
            source: SlintChangeTypeUtils.to_icon(data.change_type);
            height: Style.size.control_height;
            colorize: Palette.foreground;
        }

        Text {
            text: "\{data.count}";
            horizontal-alignment: center;
        }
    }
    VerticalLayout {
        Image {
            source: @image-url("../assets/icons/add.svg");
            colorize: Style.palette.lines-added;
            height: Style.size.control_height;
        }

        Text {
            text: difference_statistics.added_lines > 0 ? "\{difference_statistics.added_lines}" : "??";
            horizontal-alignment: center;
        }
    }

    VerticalLayout {
        Image {
            source: @image-url("../assets/icons/remove.svg");
            colorize: Style.palette.lines-removed;
            height: Style.size.control_height;
        }

        Text {
            text: difference_statistics.removed_lines > 0 ? "\{difference_statistics.removed_lines}" : "??";
            horizontal-alignment: center;
        }
    }
}
