import {
    GroupBox,
    LineEdit,
    Button,
    ListView,
    CheckBox,
    ComboBox,
    HorizontalBox,
    VerticalBox,
    Palette,
    StyleMetrics,
} from "std-widgets.slint";

import { Style } from "style.slint";
import {
    SlintReviewIdParameters,
    SlintNoteSortCriteria,
    SlintSortOrder,
    SlintReviewCallbacks,
    SlintNoteIdParamters,
    SlintFilePickerAdapter,
    SlintNote,
} from "globals.slint";
import { FilePicker } from "file_picker.slint";
import { ToolButton } from "controls/tool_button.slint";
import { SubSectionText } from "sub_section_text.slint";

component HeaderColumn inherits Rectangle {
    in property <SlintReviewIdParameters> review_id_parameters;
    in property <string> column_name;
    in property <SlintNoteSortCriteria> sort_criteria;
    in-out property <SlintNoteSortCriteria> selected_sort_criteria;
    private property <bool> is_selected: root.sort_criteria == root.selected_sort_criteria;
    private property <SlintSortOrder> sort_order: SlintSortOrder.Ascending;
    background: ta.pressed ? Palette.alternate-background : Palette.control-background;
    border-radius: Style.size.border_radius;
    border-width: Style.size.border_width;
    border-color: Palette.border;
    height: Style.size.control_height;
    HorizontalLayout {
        alignment: space-between;
        Rectangle { }

        Text {
            horizontal-alignment: center;
            vertical-alignment: center;
            overflow: elide;
            text: root.column_name;
        }

        Image {
            visible: root.is_selected;
            source: root.sort_order == SlintSortOrder.Ascending ? @image-url("../assets/icons/sort_ascending.svg") : @image-url("../assets/icons/sort_descending.svg");
            colorize: Palette.foreground;
        }
    }

    ta := TouchArea {
        clicked => {
            if (root.is_selected) {
                root.sort_order = root.sort_order == SlintSortOrder.Ascending ? SlintSortOrder.Descending : SlintSortOrder.Ascending;
            } else {
                root.selected_sort_criteria = root.sort_criteria;
            }
            SlintReviewCallbacks.set_notes_sort_parameter(root.review_id_parameters, root.sort_criteria, root.sort_order);
        }
    }
}

export component NotesView inherits Rectangle {
    in property <SlintReviewIdParameters> review_id_parameters;
    in property <[SlintNote]> notes_model;
    private property <bool> is_filter_active: false;
    private property <[length]> columns_width: [
        Style.size.image_width + 4px,
        600px,
        Style.size.image_width + 2 * Style.size.big_spacing
    ];
    private property <length> file_picker_x: 0px;
    private property <length> file_picker_y: 0px;
    private property <int> selected_note_id: -1;
    private property <string> selected_file: "";
    changed is_filter_active => {
        if (!is_filter_active) {
            SlintReviewCallbacks.set_notes_context-filter(root.review_id_parameters, "");
            SlintReviewCallbacks.set_notes_text_filter(root.review_id_parameters, "");
        }
    }
    file-picker := FilePicker {
        property <SlintNoteIdParamters> current_note_id_parameters: {
            review_id_parameters: root.review_id_parameters,
            note_id: root.selected_note_id,
        };
        selected_file: root.selected_file;
        file_model: SlintFilePickerAdapter.file_model(root.review_id_parameters);
        x: root.file_picker_x;
        y: root.file_picker_y;
        accepted(new_context) => {
            if (root.selected_note_id > -1) {
                SlintReviewCallbacks.change_note_context(current_note_id_parameters, new_context);
            } else {
                new-context-edit.text = new-context;
            }
            self.close();
        }
        set_filter(pattern) => {
            SlintFilePickerAdapter.set_filter(root.review_id_parameters, pattern);
        }
    }

    vertical-box := VerticalBox {
        spacing: Style.size.big-spacing;
        Rectangle {
            border-width: Style.size.border-width;
            border-color: Palette.border;
            vbox := VerticalLayout {
                spacing: 10px;
                padding: 10px;
                alignment: start;
                Text {
                    text: "New Note";
                    font-weight: 800;
                    horizontal-alignment: left;
                    vertical-alignment: center;
                }

                HorizontalLayout {
                    property <bool> can_add_note: !new_note_text.is-empty;
                    property <string> new_note_text <=> new-note-edit.text;
                    property <string> new_context <=> new-context-edit.text;
                    function add_note() {
                        SlintReviewCallbacks.add_note(root.review_id_parameters, new_note_text, new_context);
                        new_note_text = "";
                        new_context = "";
                    }

                    spacing: Style.size.spacing;
                    new-note-edit := LineEdit {
                        placeholder-text: @tr("Add comment here...");
                        accepted => {
                            if can_add_note {
                                add_note()
                            }
                        }
                    }

                    new-context-edit := LineEdit {
                        horizontal-alignment: left;
                        placeholder-text: @tr("Add context here...");
                        accepted => {
                            if can_add_note {
                                add_note()
                            }
                        }
                    }

                    new-file-picker-button := ToolButton {
                        source: @image-url("../assets/icons/file_picker.svg");
                        clicked => {
                            new-context-edit.clear-focus();
                            root.selected_note_id = -1;
                            root.file_picker_x = root.width - Style.size.file_picker_width - Style.size.padding * 2;
                            root.file_picker_y = vbox.height;
                            if (SlintFilePickerAdapter.contains_model_context(root.review_id_parameters, new_context)) {
                                root.selected_file = new_context;
                            } else {
                                root.selected_file = "";
                            }
                            file-picker.show();
                        }
                    }

                    ToolButton {
                        source: @image-url("../assets/icons/add.svg");
                        enabled: can_add_note;
                        clicked => {
                            add_note()
                        }
                    }
                }
            }
        }

        notes_rect := Rectangle {
            border-width: Style.size.border-width;
            border-color: Palette.border;
            notes-vertical-layout := VerticalLayout {
                spacing: Style.size.big-spacing;
                padding: 10px;
                Text {
                    text: "All Notes";
                    font-weight: 800;
                    horizontal-alignment: left;
                    vertical-alignment: center;
                }

                HorizontalLayout {
                    spacing: Style.size.spacing;
                    Rectangle {
                        width: columns_width[0];
                        Image {
                            source: @image-url("../assets/icons/filter_on.svg");
                            vertical-alignment: center;
                            horizontal-alignment: center;
                            width: Style.size.image_width;
                            colorize: Palette.foreground;
                        }
                    }

                    LineEdit {
                        width: columns_width[1];
                        placeholder-text: @tr("Filter Note Text");
                        edited(text) => {
                            SlintReviewCallbacks.set_notes_text_filter(root.review_id_parameters, text);
                        }
                    }

                    LineEdit {
                        placeholder-text: @tr("Filter Context");
                        edited(text) => {
                            SlintReviewCallbacks.set_notes_context_filter(root.review_id_parameters, text);
                        }
                    }

                    Rectangle {
                        width: columns_width[2] * 2 + Style.size.spacing;
                    }
                }

                HorizontalLayout {
                    spacing: Style.size.spacing;
                    Rectangle {
                        width: columns_width[0];
                        Image {
                            source: @image-url("../assets/icons/checklist.svg");
                            vertical-alignment: center;
                            horizontal-alignment: center;
                            width: Style.size.image_width;
                            colorize: Palette.foreground;
                        }
                    }

                    private property <SlintNoteSortCriteria> current_sort_criteria: SlintNoteSortCriteria.Text;
                    HeaderColumn {
                        review_id_parameters: root.review_id_parameters;
                        column_name: @tr("Text");
                        sort_criteria: SlintNoteSortCriteria.Text;
                        selected_sort_criteria <=> current_sort_criteria;
                        width: columns_width[1];
                    }

                    HeaderColumn {
                        review_id_parameters: root.review_id_parameters;
                        column_name: @tr("Context");
                        sort_criteria: SlintNoteSortCriteria.Context;
                        selected_sort_criteria <=> current_sort_criteria;
                    }

                    Rectangle {
                        width: columns_width[2];
                    }

                    Rectangle {
                        width: columns_width[2];
                    }
                }

                listview := ListView {
                    private property <[SlintNote]> model: SlintReviewCallbacks.note_ui_model(root.review_id_parameters);
                    for note[idx] in model: HorizontalLayout {
                        private property <SlintNoteIdParamters> note_id_parameter: {
                            review_id_parameters: root.review_id_parameters,
                            note_id: note.id,
                        };
                        spacing: Style.size.spacing;
                        padding-top: idx > 0 ? Style.size.spacing : 0px;
                        VerticalLayout {
                            alignment: center;
                            Rectangle {
                                background: Palette.control-background;
                                border-radius: Style.size.border_radius;
                                border-width: Style.size.border_width;
                                border-color: Palette.border;
                                width: columns_width[0];
                                height: columns_width[0];
                                states [
                                    is_pressed when ta.pressed: {
                                        background: Palette.alternate-background;
                                    }
                                ]
                                Image {
                                    vertical-alignment: center;
                                    horizontal-alignment: center;
                                    width: Style.size.image_width;
                                    states [
                                        is_reviewed when note.is_fixed: {
                                            source: @image-url("../assets/icons/checked.svg");
                                        }
                                    ]
                                    colorize: Palette.foreground;
                                }

                                ta := TouchArea {
                                    clicked => {
                                        SlintReviewCallbacks.change_note_is_done(note_id_parameter, !note.is_fixed);
                                    }
                                }
                            }
                        }

                        text-input := LineEdit {
                            property <string> note_text: note.text;
                            changed note_text => {
                                self.text = note_text;
                            }
                            width: root.columns_width[1];
                            text: note.text;
                            accepted(new_text) => {
                                SlintReviewCallbacks.change_note_text(note_id_parameter, new_text);
                            }
                        }

                        context-edit := LineEdit {
                            private property <string> file_name: note.context;
                            changed file_name => {
                                self.text = file_name;
                            }

                            horizontal-alignment: left;
                            text: file_name;
                            changed has-focus => {
                                if (!self.has-focus) {
                                    self.text = note.context;
                                }
                            }
                            key-pressed(event) => {
                                if (event.text == Key.Escape) {
                                    self.text = note.context;
                                    return EventResult.accept;
                                }
                                return EventResult.reject;
                            }
                            accepted(new_context) => {
                                SlintReviewCallbacks.change_note_context(note_id_parameter, new_context);
                            }
                        }

                        file-picker-button := ToolButton {
                            width: root.columns_width[2];
                            source: @image-url("../assets/icons/file_picker.svg");
                            clicked => {
                                context-edit.clear-focus();
                                root.selected_note_id = note.id;
                                root.file_picker_x = root.width - Style.size.file_picker_width - Style.size.padding * 2;
                                root.file_picker_y = notes_rect.y + listview.y + (idx + 1) * text-input.height;
                                if (SlintFilePickerAdapter.contains_model_context(root.review_id_parameters, note.context)) {
                                    root.selected_file = note.context;
                                } else {
                                    root.selected_file = "";
                                }
                                file-picker.show();
                            }
                        }

                        delete_timer := Timer {
                            interval: 2s;
                            running: false;
                            triggered => {
                                self.running = false;
                            }
                        }

                        ToolButton {
                            states [
                                active_delete_timer when delete_timer.running: {
                                    background: red;
                                }
                            ]
                            width: root.columns_width[2];
                            source: @image-url("../assets/icons/delete.svg");
                            clicked => {
                                if (delete_timer.running) {
                                    SlintReviewCallbacks.delete_note(note_id_parameter);
                                    delete_timer.stop();
                                } else {
                                    delete_timer.start();
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
