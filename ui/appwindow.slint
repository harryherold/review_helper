import {
    Button,
    VerticalBox,
    HorizontalBox,
    LineEdit,
    ListView,
    CheckBox,
    GroupBox,
    Palette,
    TabWidget,
} from "std-widgets.slint";

import { Style } from "style.slint";
import { NotesView } from "notes_view.slint";
import { FileDiffView } from "file_diff_view.slint";
import { Popup } from "popup.slint";
import { FileNotesPopup } from "file_notes_popup.slint";
import { Menu, MenuItem } from "menu.slint";
import { AppConfigPopup } from "app_settings_popup.slint";
import { DiffConfigView } from "diff_config_view.slint";
import { OverallStatistics } from "overall_statistics.slint";
import { TabView, TabViewItem } from "tabview.slint";
import { RepositorySettingsPopup } from "repository_settings_popup.slint";

import {
    Repository,
    CommitPickerAdapter,
    OverallDiffStats,
    SlintReviewHelperSettings,
    SlintStringUtils,
    Diff,
    DiffFileItem,
    Notes,
    NoteItem,
    FilePickerAdapter,
    SlintModelUtils,
    SlintRepository,
    SlintReviewHelper,
    SlintResult,
    SlintErrors,
    SlintErrorEntry,
} from "globals.slint";
import { SubSectionText } from "sub_section_text.slint";
import { ToolButton } from "tool_button.slint";
import { RepositoryView } from "respository_view.slint";

export { SlintReviewHelperSettings, FilePickerAdapter, CommitPickerAdapter, Notes, NoteItem, Diff, DiffFileItem, Repository, SlintStringUtils, OverallDiffStats, SlintModelUtils, SlintRepository, SlintReviewHelper, SlintResult, SlintErrors, SlintErrorEntry }

export component AppWindow inherits Window {
    private property <int> selected_repository_index: tab_view.current-index;
    in property <string> config_color_scheme;
    callback close;
    callback request_show_error(SlintResult);

    request_show_error(e) => {
        error-popup.show_error(e);
    }

    changed config_color_scheme => {
        Palette.color-scheme = config_color_scheme == "Dark" ? ColorScheme.dark : ColorScheme.light;
    }

    preferred-width: 1600px;
    preferred-height: 1200px;
    title: "review_helper";

    icon: @image-url("../assets/icons/review_helper.png");
    notes-popup := FileNotesPopup {
        initial_x: (root.width / 2) - (self.width / 2);
        initial_y: (root.height / 2) - (self.height / 2);
        enable_close_button: true;
    }

    app-config-popup := AppConfigPopup {
        initial_x: (root.width / 2) - (self.width / 2);
        initial_y: (root.height / 2) - (self.height / 2);
    }

    error-popup := Popup {
        function show_error(result: SlintResult) {
            self.result = result;
            self.open();
        }

        private property <SlintResult> result: SlintResult.Ok;

        title: "Error";
        initial_x: (root.width / 2) - (self.width / 2);
        initial_y: (root.height / 2) - (self.height / 2);

        VerticalLayout {
            alignment: center;

            padding-bottom: Style.size.big-spacing;
            padding-left: Style.size.big-spacing;
            padding-right: Style.size.big-spacing;
            spacing: Style.size.big-spacing;

            HorizontalLayout {
                alignment: space-around;
                spacing: Style.size.spacing;

                Image {
                    width: Style.size.image-width;
                    source: @image-url("../assets/icons/failed.svg");
                }

                Text {
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    wrap: word-wrap;
                    max-width: Style.size.control-width * 2;
                    text: {
                        if (error-popup.result == SlintResult.RepositoryExists) {
                            return "Repository already exists!";
                        }
                        if (error-popup.result == SlintResult.GitCommandFailed) {
                            return "Could not exec git commands!";
                        }
                        if (error-popup.result == SlintResult.NoGitDirectory) {
                            return "This folder is not Git-controlled!";
                        }
                        if (error-popup.result == SlintResult.StoreFailed) {
                            return "Could store repository data!";
                        }
                        if (error-popup.result == SlintResult.ModelItemNotExists) {
                            return "Could not find model item!";
                        }
                        return "";
                    }
                }
            }

            HorizontalLayout {
                alignment: center;
                Button {
                    width: Style.size.control-width;
                    text: "Ok";
                    clicked => {
                        error-popup.close();
                    }
                }
            }
        }
    }

    repository-settings-popup := RepositorySettingsPopup {
        initial_x: (root.width / 2) - (self.width / 2);
        initial_y: (root.height / 2) - (self.height / 2);
        base-branch-changed(base-branch) => {
            SlintReviewHelper.repositories[root.selected_repository_index].base-branch = base-branch;
        }
    }

    VerticalLayout {
        menu-rect := Rectangle {
            height: 40px;

            HorizontalLayout {
                alignment: space-between;
                spacing: Style.size.spacing;

                HorizontalLayout {
                    spacing: Style.size.spacing;

                    Menu {
                        text: "File";
                        MenuItem {
                            text: "Close";
                            clicked => {
                                root.close()
                            }
                        }
                    }

                    Menu {
                        text: "Settings";

                        MenuItem {
                            text: "ReviewHelper";
                            clicked => {
                                app-config-popup.open()
                            }
                        }

                        MenuItem {
                            enabled: root.selected_repository_index != -1;
                            text: "Respository";
                            clicked => {
                                repository-settings-popup.show(SlintReviewHelper.repositories[root.selected_repository_index]);
                            }
                        }
                    }
                }
            }
        }

        tab_view := TabView {
            model: SlintReviewHelper.repository_names;
            request-create => {
                let result = SlintReviewHelper.new_repository();
                if (result != SlintResult.Ok) {
                    error-popup.show_error(result);
                } else {
                    self.set_current_index(self.model.length - 1);
                }
            }

            for repository[idx] in SlintReviewHelper.repositories: TabViewItem {
                index: idx;
                current-index: parent.current-index;

                RepositoryView {
                    repository: repository;
                }
            }
        }
    }
}
