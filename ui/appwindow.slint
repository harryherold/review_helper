import { ErrorPopup } from "error_popup.slint";

export { 
    SlintReviewCallbacks,
    SlintRepositoryCallbacks,
    SlintReviewHelperSettings,
    FilePickerAdapter,
    CommitPickerAdapter,
    Notes,
    NoteItem,
    Diff,
    DiffFileItem,
    Repository,
    SlintStringUtils,
    OverallDiffStats,
    SlintModelUtils,
    SlintRepository,
    SlintReviewHelper,
    SlintResult,
    SlintErrors,
    SlintErrorEntry,
    SlintDiffRange,
    SlintReviewIdParameters,
    SlintNoteIdParamters,
    SlintFileDiffIdParamters,
    SlintCommitPickerAdapter,
    SlintCommit,
    SlintCommitSortCriterion,
    SlintFilePickerAdapter,
}

export component AppWindow inherits Window {
    private property <int> selected_repository_index <=> tab-view.current-index;
    in property <string> config_color_scheme;
    callback close;
    callback request_show_error(SlintResult);

    request_show_error(e) => {
        error-popup.show_error(e);
    }

    changed config_color_scheme => {
        Palette.color-scheme = config_color_scheme == "Dark" ? ColorScheme.dark : ColorScheme.light;
    }

    preferred-width: 1600px;
    preferred-height: 1200px;
    title: "review_helper";

    icon: @image-url("../assets/icons/review_helper.png");
    notes-popup := FileNotesPopup {
        initial_x: (root.width / 2) - (self.width / 2);
        initial_y: (root.height / 2) - (self.height / 2);
        enable_close_button: true;
    }

    app-config-popup := AppConfigPopup {
        initial_x: (root.width / 2) - (self.width / 2);
        initial_y: (root.height / 2) - (self.height / 2);
    }

    error-popup := ErrorPopup {
        initial_x: (root.width / 2) - (self.width / 2);
        initial_y: (root.height / 2) - (self.height / 2);
    }

    repository-settings-popup := RepositorySettingsPopup {
        initial_x: (root.width / 2) - (self.width / 2);
        initial_y: (root.height / 2) - (self.height / 2);
        base-branch-changed(base-branch) => {
            SlintReviewHelper.repositories[root.selected_repository_index].base-branch = base-branch;
            SlintRepositoryCallbacks.repository_changed(SlintReviewHelper.repositories[root.selected_repository_index].id, base-branch);
        }
    }

    VerticalLayout {
        menu-rect := Rectangle {
            height: 40px;

            HorizontalLayout {
                alignment: space-between;
                spacing: Style.size.spacing;

                HorizontalLayout {
                    spacing: Style.size.spacing;

                    Menu {
                        text: "File";
                        MenuItem {
                            text: "Close";
                            clicked => {
                                root.close()
                            }
                        }
                    }

                    Menu {
                        text: "Settings";

                        MenuItem {
                            text: "ReviewHelper";
                            clicked => {
                                app-config-popup.open()
                            }
                        }

                        MenuItem {
                            enabled: root.selected_repository_index != -1;
                            text: "Respository";
                            clicked => {
                                repository-settings-popup.show(SlintReviewHelper.repositories[root.selected_repository_index]);
                            }
                        }
                    }
                }
            }
        }

        tab-view := TabView {
            model: SlintReviewHelper.repository_names;
            request-create => { SlintReviewHelper.new_repository() }
            for repository[idx] in SlintReviewHelper.repositories: RepositoryTabViewItem {
                index: idx;
                current-index <=> parent.current-index;
                repository_id: repository.id;
                repository_name: repository.name;
                review_model: repository.review_model;
            }
        }
    }
}
