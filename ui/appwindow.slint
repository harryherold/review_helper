export component AppWindow inherits Window {
    private property <int> selected_repository_index <=> tab-view.current-index;
    in property <string> config_color_scheme;
    callback close;
    callback request_show_error();
    request_show_error() => {
        error-popup.show();
    }

    changed config_color_scheme => {
        Palette.color-scheme = config_color_scheme == @tr("Dark") ? ColorScheme.dark : ColorScheme.light;
    }
    preferred-width: 1600px;
    preferred-height: 1200px;
    title: @tr("review_helper");
    icon: @image-url("../assets/icons/review_helper.png");
    notes-popup := FileNotesPopup {
        initial_x: (root.width / 2) - (self.width / 2);
        initial_y: (root.height / 2) - (self.height / 2);
        enable_close_button: true;
    }

    error-popup := ErrorPopup {
        x: (root.width / 2) - (self.width / 2);
        y: (root.height / 2) - (self.height / 2);
    }

    app-config-popup := AppConfigPopup {
        x: (root.width / 2) - (self.width / 2);
        y: (root.height / 2) - (self.height / 2);
    }

    repository-settings-popup := RepositorySettingsPopup {
        initial_x: (root.width / 2) - (self.width / 2);
        initial_y: (root.height / 2) - (self.height / 2);
        base-branch-changed(base-branch) => {
            SlintReviewHelper.repositories[root.selected_repository_index].base-branch = base-branch;
            SlintRepositoryCallbacks.repository_changed(SlintReviewHelper.repositories[root.selected_repository_index].id, base-branch);
        }
    }

    tab-view := TabView {
        layout_padding: 0px;
        model: SlintReviewHelper.repository_names;
        settings_button_enabled: true;
        request-create => {
            SlintReviewHelper.new_repository();
        }
        request-open-settings => {
            app-config-popup.show();
        }
        for repository[idx] in SlintReviewHelper.repositories: RepositoryTabViewItem {
            index: idx;
            current-index <=> parent.current-index;
            repository_id: repository.id;
            repository_name: repository.name;
            review_model: repository.review_model;
        }
    }
}
