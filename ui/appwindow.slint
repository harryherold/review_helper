import {
    Button,
    VerticalBox,
    HorizontalBox,
    LineEdit,
    ListView,
    CheckBox,
    GroupBox,
    Palette,
    TabWidget,
} from "std-widgets.slint";

import { Style } from "style.slint";
import { NotesView } from "notes_view.slint";
import { FileDiffView } from "file_diff_view.slint";
import { Popup } from "popup.slint";
import { FileNotesPopup } from "file_notes_popup.slint";
import { Menu, MenuItem } from "menu.slint";
import { AppConfigPopup } from "app_config_popup.slint";
import { DiffConfigView } from "diff_config_view.slint";
import { OverallStatistics } from "overall_statistics.slint";

import {
    Repository,
    CommitPickerAdapter,
    OverallDiffStats,
    AppConfig,
    StringUtils,
    Diff,
    DiffFileItem,
    Notes,
    NoteItem,
    FilePickerAdapter,
    ModelUtils,
    RepositoryUi,
    RepositoriesUi,
    Result,
    Errors,
    ErrorEntry,
} from "globals.slint";
import { SubSectionText } from "sub_section_text.slint";
import { ToolButton } from "tool_button.slint";

export { AppConfig, FilePickerAdapter, CommitPickerAdapter, Notes, NoteItem, Diff, DiffFileItem, Repository, StringUtils, OverallDiffStats, ModelUtils, RepositoryUi, RepositoriesUi, Result, Errors, ErrorEntry }

export component AppWindow inherits Window {
    in property <string> config_color_scheme;
    callback close;

    changed config_color_scheme => {
        Palette.color-scheme = config_color_scheme == "Dark" ? ColorScheme.dark : ColorScheme.light;
    }

    preferred-width: 1600px;
    preferred-height: 1200px;
    title: "review_helper";

    icon: @image-url("../assets/icons/review_helper.png");
    notes-popup := FileNotesPopup {
        initial_x: (root.width / 2) - (self.width / 2);
        initial_y: (root.height / 2) - (self.height / 2);
        enable_close_button: true;
    }

    app-config-popup := AppConfigPopup {
        initial_x: (root.width / 2) - (self.width / 2);
        initial_y: (root.height / 2) - (self.height / 2);
    }

    error-popup := Popup {
        function show_error(result: Result) {
            self.result = result;
            self.open();
        }

        private property <Result> result: Result.Ok;

        title: "Error";
        initial_x: (root.width / 2) - (self.width / 2);
        initial_y: (root.height / 2) - (self.height / 2);

        VerticalLayout {
            alignment: center;

            padding-bottom: Style.size.big-spacing;
            padding-left: Style.size.big-spacing;
            padding-right: Style.size.big-spacing;
            spacing: Style.size.big-spacing;

            HorizontalLayout {
                alignment: space-around;
                spacing: Style.size.spacing;

                Image {
                    width: Style.size.image-width;
                    source: @image-url("../assets/icons/failed.svg");
                }

                Text {
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    wrap: word-wrap;
                    max-width: Style.size.control-width * 2;
                    text: {
                        if (error-popup.result == Result.RepositoryExists) {
                            return "Repository already exists!";
                        }
                        if (error-popup.result == Result.GitCommandFailed) {
                            return "Could not exec git commands!";
                        }
                        if (error-popup.result == Result.NoGitDirectory) {
                            return "This folder is not Git-controlled!";
                        }
                        if (error-popup.result == Result.StoreFailed) {
                            return "Could store repository data!";
                        }
                        return "";
                    }
                }
            }

            HorizontalLayout {
                alignment: center;
                Button {
                    width: Style.size.control-width;
                    text: "Ok";
                    clicked => {
                        error-popup.close();
                    }
                }
            }
        }
    }

    VerticalLayout {
        menu-rect := Rectangle {
            height: 40px;

            HorizontalLayout {
                alignment: space-between;
                spacing: Style.size.spacing;

                HorizontalLayout {
                    spacing: Style.size.spacing;

                    Menu {
                        text: "File";
                        MenuItem {
                            text: "Close";
                            clicked => {
                                root.close()
                            }
                        }
                    }

                    Menu {
                        text: "Edit";

                        MenuItem {
                            text: "Config";
                            clicked => {
                                app-config-popup.open()
                            }
                        }
                    }
                }

                // if Project.has_modifications: Rectangle {
                //     width: Style.size.control_small_width;
                //     border-radius: Style.size.border_radius;
                //     border-width: Style.size.border_width;
                //     states [
                //         is_active when ta.has-hover: {
                //             background: Palette.control-background;
                //         }
                //     ]
                //     image := Image {
                //         source: @image-url("../assets/icons/save.svg");
                //         vertical-alignment: center;
                //         horizontal-alignment: center;
                //         colorize: Palette.foreground;

                //         ta := TouchArea {
                //             clicked => {
                //                 Project.save()
                //             }
                //         }
                //     }
                // }
            }
        }

        for error in Errors.model: HorizontalLayout {
            spacing: 5px;

            Text {
                text: error.text;
            }
        }

        property <int> selected_repository_id: -1;
        HorizontalLayout {
            alignment: start;
            for repository in RepositoriesUi.repositories: Button {
                property <int> selected_id: selected_repository_id;
                changed selected_id => {
                    self.checked = selected_id == repository.id;
                }
                text: repository.name;
                checkable: true;
                clicked => {
                    if (selected_repository_id == repository.id) {
                        selected_repository_id = -1;
                    } else {
                        selected_repository_id = repository.id;
                    }
                }
            }
            ToolButton {
                source: @image-url("../assets/icons/add.svg");
                clicked => {
                    let result = RepositoriesUi.new_repository();
                    if (result != Result.Ok) {
                        error-popup.show_error(result);
                    }
                }
            }
        }

        Rectangle { }

        // if Project.is_loaded: TabWidget {
        //     Tab {
        //         title: "File Diff";

        //         Rectangle {
        //             background: Palette.control-background;

        //             VerticalBox {
        //                 spacing: Style.size.spacing;
        //                 SubSectionText {
        //                     text: "Repository:";
        //                 }

        //                 DiffConfigView { }

        //                 SubSectionText {
        //                     visible: Repository.is_loaded;
        //                     text: "Statistics:";
        //                 }

        //                 if Repository.is_loaded: OverallStatistics { }

        //                 SubSectionText {
        //                     visible: Repository.is_loaded;
        //                     text: "Differences:";
        //                 }

        //                 if Repository.is_loaded: FileDiffView { }
        //             }
        //         }
        //     }

        //     Tab {
        //         title: "Notes";

        //         NotesView { }
        //     }
        // }
        // if !Project.is_loaded: HorizontalBox {
        //     alignment: center;
        //     Image {
        //         source: @image-url("../assets/icons/warning.svg");
        //         colorize: Palette.foreground;
        //     }

        //     Text {
        //         vertical-alignment: center;
        //         text: "No project loaded";
        //         font-size: 18px;
        //     }
        // }
    }
}
