import {
    VerticalBox,
    TabWidget,
    ListView,
    Palette,
    LineEdit,
} from "std-widgets.slint";
import { ToolButton } from "tool_button.slint";
import { Style } from "style.slint";
import {
    SlintReviewHelper,
    SlintRepositoryCallbacks,
    SlintReview,
    SlintReviewCallbacks,
} from "globals.slint";
import { TabButton, TabCreateButton, TabViewItem } from "tabview.slint";

export component RepositoryTabViewItem inherits TabViewItem {
    in property <int> repository_id;
    in property <string> repository_name;
    in property <[SlintReview]> review_model;
    private property <bool> is_repository_loaded: false;
    private property <int> selected_review_id: -1;

    changed is_active => {
        if (root.is_active && !root.is_repository_loaded) {
            SlintRepositoryCallbacks.load_repository(root.repository_id);
            root.is_repository_loaded = true;
        }
    }
    HorizontalLayout {
        Rectangle {
            width: 15%;
            VerticalLayout {
                padding-left: 5px;
                padding-right: 5px;
                spacing: Style.size.spacing;
                Text {
                    height: Style.size.control-height;
                    vertical-alignment: center;
                    horizontal-alignment: center;
                    text: "Reviews";
                }

                TabCreateButton {
                    height: Style.size.control-height;
                }

                ListView {
                    visible: root.review_model.length > 0; // NOTE workaround to get ListView visible with their elements
                    for review[idx] in root.review_model: Rectangle {
                        height: Style.size.control-height + Style.size.spacing;
                        TabButton {
                            tab-text: review.name;
                            height: Style.size.control-height;
                            is-selected: root.selected_review_id == review.id;
                            clicked => {
                                root.selected_review_id = review.id;
                                if (!review.is_loaded) {
                                    SlintReviewCallbacks.load_review(root.repository_id, review.id);
                                }
                            }
                        }
                    }
                }
            }
        }

        Rectangle {
            width: 1px;
            height: 100%;
            background: Palette.border;
        }

        Rectangle {
            private property <int> review_index: SlintReviewCallbacks.review_id_to_index(root.selected_review_id, root.review_model);
            width: 85%;

            if review_index != -1: VerticalLayout {
                HorizontalLayout {
                    spacing: Style.size.spacing;
                    TabWidget {
                        Tab {
                            title: "FileDiff";
                            Rectangle {
                                VerticalLayout {
                                    alignment: start;
                                    spacing: Style.size.spacing;
                                    HorizontalLayout {
                                        spacing: Style.size.spacing;
                                        Text {
                                            text: "start";
                                        }

                                        LineEdit {
                                            text: root.review_model[review_index].start_diff;
                                        }
                                    }

                                    HorizontalLayout {
                                        spacing: Style.size.spacing;
                                        Text {
                                            text: "end";
                                        }

                                        LineEdit {
                                            text: root.review_model[review_index].end_diff;
                                        }
                                    }

                                    HorizontalLayout {
                                        alignment: start;
                                        spacing: Style.size.spacing;

                                        Text {
                                            text: "FileDiffs count";
                                        }

                                        Text {
                                            text: root.review_model[review_index].file_diff_model.length;
                                        }
                                    }
                                }
                            }
                        }

                        Tab {
                            title: "Notes";
                            Rectangle {
                                VerticalLayout {
                                    alignment: start;
                                    spacing: Style.size.spacing;
                                    HorizontalLayout {
                                        alignment: start;
                                        spacing: Style.size.spacing;
                                        Text {
                                            text: "Notes count";
                                        }

                                        Text {
                                            text: root.review_model[review_index].note_model.length;
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
