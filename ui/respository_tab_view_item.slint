import {
    VerticalBox,
    TabWidget,
    ListView,
    Palette,
    LineEdit,
    CheckBox,
    Button,
    HorizontalBox,
    ComboBox,
    Slider,
    Switch,
} from "std-widgets.slint";
import { ToolButton } from "controls/tool_button.slint";
import { Style } from "style.slint";
import {
    SlintCommitPickerAdapter,
    SlintChangeTypeUtils,
    SlintDiffRange,
    SlintReviewHelper,
    SlintRepositoryCallbacks,
    SlintReview,
    SlintReviewCallbacks,
    SlintStringUtils,
    SlintReviewIdParameters,
    SlintFileDiffIdParamters,
    SlintNoteIdParamters,
    SlintFilePickerAdapter,
    SlintFilterReviewState,
} from "globals.slint";
import {
    TabView,
    TabViewItem,
    TabCreateButton,
    TabButton,
} from "controls/tabview.slint";
import { CommitPicker } from "commit_picker.slint";
import { FilePicker } from "file_picker.slint";
import { RepositorySettingsTab } from "repository_settings_tab.slint";
import { ReviewSelectionTab } from "review_selection_tab.slint";
import { ReviewView } from "review_view.slint";

export component RepositoryTabViewItem inherits TabViewItem {
    in property <int> repository_id;
    in property <string> repository_name;
    in property <[SlintReview]> review_model;
    in property <string> base_branch;
    private property <bool> is_repository_loaded: false;
    private property <SlintReviewIdParameters> review_id_parameters: {
        repository_id: root.repository_id,
        review_id: -1,
    };
    private property <bool> should_show_reviews: true;
    function load_repository() {
        if root.is_active {
            if !root.is_repository_loaded {
                SlintRepositoryCallbacks.load_repository(root.repository_id);
                root.is_repository_loaded = true;
            }
            SlintCommitPickerAdapter.refresh(root.repository_id);
        }
    }
    public function select_review(id: int) {
        root.review_id_parameters.review-id = id;
    }
    changed is_active => {
        load_repository();
    }
    init => {
        load_repository();
    }
    HorizontalLayout {
        if should_show_reviews: Rectangle {
            VerticalLayout {
                padding-left: Style.size.spacing;
                padding-right: Style.size.spacing;
                spacing: Style.size.spacing;
                TabView {
                    create_button_enabled: false;
                    hide_button_enable: true;
                    model: [@tr("Reviews"), @tr("Settings")];
                    alignment: center;
                    max_child_width: Math.max(st.preferred-width, s.preferred-width);
                    request-hide => {
                        should_show_reviews = false;
                    }
                    request-show => {
                        should_show_reviews = true;
                    }
                    st := ReviewSelectionTab {
                        private property <int> incomming_selected_id: root.review_id_parameters.review-id;
                        changed incomming_selected_id => {
                            if incomming_selected_id != self.selected_review_id {
                                self.selected_review_id = incomming_selected_id;
                                self.scroll_to(incomming_selected_id);
                            }
                        }
                        index: 0;
                        current-index <=> parent.current-index;
                        repository_id: root.repository_id;
                        review_model: root.review_model;
                        change_review_id(id) => {
                            if id != self.selected_review_id {
                                self.selected_review_id = id;
                            }
                            if id != root.review_id_parameters.review-id {
                                SlintReviewCallbacks.load_review({
                                    repository_id: root.repository_id,
                                    review_id: id,
                                });
                                root.review_id_parameters.review-id = id;
                            }
                        }
                    }

                    s := RepositorySettingsTab {
                        index: 1;
                        current-index <=> parent.current-index;
                        repository_id: root.repository_id;
                        base_branch: root.base_branch;
                    }
                }
            }
        }

        if !should_show_reviews: Rectangle {
            width: Style.size.image_width;
            Image {
                source: @image-url("../assets/icons/to_right.svg");
                colorize: Palette.foreground;
                width: Style.size.image_width;
            }

            background: root.background.darker(0.1);
            states [
                has_active_hover when ta.has-hover: {
                    background: Style.palette.background.darker(0.2);
                }
            ]

            ta := TouchArea {
                clicked => {
                    should_show_reviews = !should_show_reviews;
                }
            }
        }

        ReviewView {
            review_id_parameters: root.review_id_parameters;
            review_model: root.review_model;
        }
    }
}
